{
  "name": "homepilot-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit && npm run typecheck --prefix apps/operator-console",
    "dev:api": "ts-node main.ts",
    "dev:ui": "npm run dev --prefix apps/operator-console",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:ui\"",
    "build": "tsc",
    "start": "node dist/main.js"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "@types/ws": "^8.5.10"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "ws": "^8.16.0"
  }
}
