{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "types": ["jest", "node"],
    "jsx": "react-jsx"
  },
  "include": [
    "packages/**/*",
    "apps/api/**/*",
    "services/**/*",
    "__tests__/**/*",
    "main.ts",
    "bootstrap.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.js",
    "apps/operator-console"
  ]
}
