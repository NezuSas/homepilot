{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "types": ["jest", "node"]
  },
  "include": [
    "packages/**/*",
    "apps/**/*",
    "services/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.js"
  ]
}
