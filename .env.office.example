# HomePilot Edge - instalacion de cliente con Home Assistant existente.
# El instalador copia este archivo a .env solo si aun no existe.
# No coloques aqui el token de Home Assistant: se guarda durante el onboarding.

# Produccion: false obliga a crear el primer administrador desde la UI si la DB esta vacia.
HOMEPILOT_DEV_BOOTSTRAP=false
HOMEPILOT_DB_PATH=/app/data/homepilot.db
HOMEPILOT_BACKUP_DIR=/app/backups

# Home Assistant ya existente en la miniPC. HomePilot no crea ni administra ese contenedor.
INTERNAL_HA_URL=http://host.docker.internal:8123

# Puertos publicados por la miniPC.
HOMEPILOT_API_PORT=3000
HOMEPILOT_UI_PORT=8080
HOMEPILOT_TTS_PORT=8088
HOMEPILOT_STT_PORT=8090
HOMEPILOT_OLLAMA_PORT=11434
HOMEPILOT_CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080
HOMEPILOT_STARTUP_TIMEOUT_SECONDS=180

# URL que el navegador usa para alcanzar la API.
# Para Cloudflare SSH con -L 13000:127.0.0.1:3000: http://localhost:13000
# Para acceso LAN directo, reemplaza por http://IP_DE_LA_MINIPC:3000 antes de construir la UI.
VITE_API_URL=http://localhost:13000

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT_MS=30000

ASSISTANT_PLANNER_V2_SHADOW=true
ASSISTANT_PLANNER_V2_SHADOW_SAMPLE_RATE=1
ASSISTANT_PLANNER_V2_SHADOW_FORCE=true
ASSISTANT_PLANNER_V2_SHADOW_LIGHT_PROMPT=true
ASSISTANT_PLANNER_V2_SHADOW_ULTRA_LIGHT_PROMPT=true
ASSISTANT_PLANNER_V2_SHADOW_TIMEOUT_MS=20000
ASSISTANT_PLANNER_V2_EXECUTION=true
ASSISTANT_PLANNER_V2_SHADOW_MODEL=qwen2.5:1.5b

TTS_PROVIDER=piper
TTS_BASE_URL=http://homepilot-tts:8088
TTS_TIMEOUT_MS=12000
PIPER_VOICE_ES=es_ES-sharvard-medium
PIPER_VOICE_EN=en_US-lessac-medium
PIPER_SYNTHESIS_TIMEOUT_SECONDS=20

STT_PROVIDER=whisper-local
STT_BASE_URL=http://homepilot-stt:8090
STT_TIMEOUT_MS=30000
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=3
WHISPER_VAD_MIN_SILENCE_MS=650
WHISPER_VAD_SPEECH_PAD_MS=400
WHISPER_MAX_AUDIO_BYTES=9000000
WHISPER_HOTWORDS=Ok Nezu,OK Nezu,Okey Nezu,Okay Nezu,Okei Nezu,ok Nesu,ok Ne Su,ok Nezo,ok Neso
