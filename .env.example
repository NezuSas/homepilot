# HomePilot Edge — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Auth Bootstrap ────────────────────────────────────────────────────────────
# Set to 'true' ONLY for local development.
# Creates admin user with credentials:  admin / admin
# Default (production): a secure random password is printed once at first boot.
HOMEPILOT_DEV_BOOTSTRAP=false

# ─── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database. Ensure this is mapped correctly in Docker or set to your local dev path.
HOMEPILOT_DB_PATH=./data/homepilot.db
# Directory where backups will be stored.
HOMEPILOT_BACKUP_DIR=./backups

# ─── Home Assistant ────────────────────────────────────────────────────────────
# Internal Docker network URL for the HA service.
# INTERNAL_HA_URL=http://homeassistant:8123

# ─── Ollama Assistant (Optional) ───────────────────────────────────────────────
# Enable LLM-based intent interpretation. Fallback is always available.
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT_MS=8000
