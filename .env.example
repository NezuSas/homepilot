# HomePilot Edge — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Auth Bootstrap ────────────────────────────────────────────────────────────
# Set to 'true' ONLY for local development.
# Creates admin user with credentials: admin / admin when the database is empty.
# Default (production): false. The first user is created through the onboarding UI.
HOMEPILOT_DEV_BOOTSTRAP=false
# Perfil: ha_companion administra el Home Assistant incluido en docker-compose.yml.
HOMEPILOT_INSTALLATION_PROFILE=ha_companion

# ─── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database. Ensure this is mapped correctly in Docker or set to your local dev path.
HOMEPILOT_DB_PATH=./data/homepilot.db
# WAL is optimal for Linux miniPC installations. Use DELETE only when Docker
# mounts the database from a Windows host filesystem.
HOMEPILOT_SQLITE_JOURNAL_MODE=WAL
# Directory where backups will be stored.
HOMEPILOT_BACKUP_DIR=./backups

# Ciudad mostrada en la cabecera de Inicio. Se inyecta al compilar la UI.
VITE_HOME_CITY=Cuenca

# ─── Home Assistant ────────────────────────────────────────────────────────────
# Internal Docker network URL for the HA service.
# INTERNAL_HA_URL=http://homeassistant:8123

# ─── Ollama Assistant (Optional) ───────────────────────────────────────────────
# Enable LLM-based intent interpretation. Fallback is always available.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT_MS=30000

# ─── Professional No-Key Voice (Optional) ─────────────────────────────────────
# Local Docker service using Piper voices. No API keys required.
TTS_PROVIDER=piper
TTS_BASE_URL=http://homepilot-tts:8088
TTS_TIMEOUT_MS=12000
PIPER_VOICE_ES=es_ES-davefx-medium
PIPER_VOICE_EN=en_US-lessac-medium
PIPER_SYNTHESIS_TIMEOUT_SECONDS=20

# ─── Local Speech-To-Text (Optional) ──────────────────────────────────────────
# Local Docker service using faster-whisper. No API keys required.
STT_PROVIDER=whisper-local
STT_BASE_URL=http://homepilot-stt:8090
STT_TIMEOUT_MS=30000
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=3
WHISPER_VAD_MIN_SILENCE_MS=650
WHISPER_VAD_SPEECH_PAD_MS=400
WHISPER_MAX_AUDIO_BYTES=9000000
